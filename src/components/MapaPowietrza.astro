---
// Interaktywna mapa jakości powietrza dla Mysłowic.
// Dane z serwerowego endpointu /api/powietrze.json (GIOŚ + Airly + Syngeos).
---
<section class="mapa-sekcja" aria-label="Mapa jakości powietrza w Mysłowicach">
  <div class="mapa-head">
    <span class="eyebrow">Jakość powietrza teraz</span>
    <p class="mapa-sub">Czujniki w Mysłowicach i okolicy. Kolor punktu odpowiada bieżącej jakości powietrza. Mysłowice nie mają stacji GIOŚ — pokazujemy najbliższe oficjalne pomiary oraz lokalne pyłomierze.</p>
  </div>

  <div id="mapa-powietrza" class="mapa"></div>

  <div class="mapa-legenda">
    <span><i style="background:#57b108"></i> bardzo dobry</span>
    <span><i style="background:#b0dd10"></i> dobry</span>
    <span><i style="background:#ffd911"></i> umiarkowany</span>
    <span><i style="background:#e58100"></i> dostateczny</span>
    <span><i style="background:#e50000"></i> zły</span>
    <span><i style="background:#990000"></i> bardzo zły</span>
  </div>
  <p class="mapa-info" id="mapa-info">Ładowanie danych…</p>
</section>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />

<style>
  .mapa-sekcja { background: var(--bg-blue-soft); border: 1px solid var(--border); border-radius: var(--radius); padding: 1.4rem; }
  .mapa-sub { color: var(--text-muted); font-size: 0.95rem; margin: 0.2rem 0 1rem; max-width: 70ch; }
  .mapa { height: 460px; width: 100%; border-radius: var(--radius-sm); overflow: hidden; z-index: 0; background: #dfe7ee; }
  .mapa-legenda { display: flex; flex-wrap: wrap; gap: 0.4rem 1rem; margin-top: 0.9rem; font-size: 0.82rem; color: var(--text-muted); }
  .mapa-legenda i { display: inline-block; width: 12px; height: 12px; border-radius: 50%; margin-right: 0.35rem; vertical-align: -1px; }
  .mapa-info { font-size: 0.82rem; color: var(--text-muted); margin: 0.6rem 0 0; }
  :global(.mapa-btn-mys) { background: #fff; border: 0; cursor: pointer; font: 600 0.82rem var(--font); color: var(--navy); padding: 0.4rem 0.7rem; border-radius: var(--radius-sm); box-shadow: 0 1px 4px rgba(16,49,79,0.3); }
  :global(.mapa-btn-mys:hover) { background: var(--bg-blue-soft); color: var(--blue); }
  :global(.mapa-hint) { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; background: rgba(16,49,79,0.45); color: #fff; font-weight: 600; font-size: 1rem; text-align: center; padding: 1rem; opacity: 0; pointer-events: none; transition: opacity 0.2s; z-index: 500; }
  :global(.mapa-hint.show) { opacity: 1; }
  :global(.aq-popup .leaflet-popup-content-wrapper) { padding: 0; overflow: hidden; border-radius: 14px; box-shadow: 0 8px 28px rgba(16,49,79,0.25); }
  :global(.aq-popup .leaflet-popup-content) { margin: 0; width: 240px !important; font-family: var(--font); }
  :global(.aqp-hd) { padding: 0.8rem 0.9rem 0.7rem; }
  :global(.aqp-src) { font-size: 0.66rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; opacity: 0.85; }
  :global(.aqp-name) { font-size: 0.97rem; font-weight: 600; line-height: 1.25; margin-top: 0.1rem; }
  :global(.aqp-idx) { font-size: 0.9rem; font-weight: 500; margin-top: 0.3rem; }
  :global(.aqp-bd) { padding: 0.5rem 0.9rem 0.8rem; background: #fff; }
  :global(.aqp-row) { display: flex; justify-content: space-between; align-items: baseline; padding: 0.32rem 0; border-bottom: 1px solid var(--border); }
  :global(.aqp-row:last-of-type) { border-bottom: 0; }
  :global(.aqp-row span) { color: var(--text-muted); font-size: 0.85rem; }
  :global(.aqp-row b) { color: var(--navy); font-size: 1.05rem; }
  :global(.aqp-row small) { color: var(--text-muted); font-weight: 400; font-size: 0.68rem; }
  :global(.aqp-note) { color: var(--text-muted); font-size: 0.82rem; padding: 0.2rem 0; }
  :global(.aqp-more) { display: inline-block; margin-top: 0.55rem; font-size: 0.85rem; font-weight: 600; color: var(--blue); }
</style>

<script is:inline>
  (function () {
    function init() {
      var map = L.map('mapa-powietrza', { scrollWheelZoom: false }).setView([50.2074, 19.1374], 11);
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        maxZoom: 18,
        attribution: '&copy; OpenStreetMap',
      }).addTo(map);

      // znacznik centrum Mysłowic
      L.marker([50.2074, 19.1374]).addTo(map).bindPopup('<div class="aq-pop"><h4>Mysłowice</h4></div>');

      // przycisk: przybliż do Mysłowic
      var BtnMys = L.Control.extend({
        options: { position: 'topleft' },
        onAdd: function () {
          var b = L.DomUtil.create('button', 'leaflet-bar mapa-btn-mys');
          b.type = 'button';
          b.title = 'Przybliż do Mysłowic';
          b.textContent = 'Mysłowice';
          L.DomEvent.disableClickPropagation(b);
          L.DomEvent.on(b, 'click', function (e) {
            L.DomEvent.stop(e);
            map.setView([50.2074, 19.1374], 13);
          });
          return b;
        },
      });
      map.addControl(new BtnMys());

      // zoom scrollem tylko z Ctrl + podpowiedź
      var mapEl = document.getElementById('mapa-powietrza');
      var hint = L.DomUtil.create('div', 'mapa-hint', mapEl);
      hint.textContent = 'Przytrzymaj Ctrl i przewiń, aby przybliżyć';
      var hintT;
      mapEl.addEventListener('wheel', function (e) {
        if (e.ctrlKey) {
          e.preventDefault();
          var d = e.deltaY < 0 ? 1 : -1;
          map.setZoomAround(map.mouseEventToContainerPoint(e), map.getZoom() + d);
          hint.classList.remove('show');
        } else {
          hint.classList.add('show');
          clearTimeout(hintT);
          hintT = setTimeout(function () { hint.classList.remove('show'); }, 1300);
        }
      }, { passive: false });

      function kontrast(hex) {
        var h = (hex || '').replace('#', '');
        if (h.length !== 6) return '#10314F';
        var r = parseInt(h.substr(0, 2), 16), g = parseInt(h.substr(2, 2), 16), b = parseInt(h.substr(4, 2), 16);
        return (0.299 * r + 0.587 * g + 0.114 * b) > 150 ? '#10314F' : '#ffffff';
      }

      fetch('/api/powietrze')
        .then(function (r) { return r.json(); })
        .then(function (data) {
          var pkt = (data && data.punkty) || [];
          var info = document.getElementById('mapa-info');
          var liczba = { 'GIOŚ': 0, 'Airly': 0, 'Syngeos': 0, 'LookO2': 0 };
          var grupa = [];
          pkt.forEach(function (p) {
            if (typeof p.lat !== 'number' || typeof p.lng !== 'number') return;
            liczba[p.zrodlo] = (liczba[p.zrodlo] || 0) + 1;
            var m = L.circleMarker([p.lat, p.lng], {
              radius: 10, fillColor: p.kolor || '#9aa7b0',
              color: '#fff', weight: 2, opacity: 1, fillOpacity: 0.95,
            }).addTo(map);
            var rows = '';
            if (p.pm10 != null) rows += '<div class="aqp-row"><span>PM10</span><b>' + p.pm10 + ' <small>µg/m³</small></b></div>';
            if (p.pm25 != null) rows += '<div class="aqp-row"><span>PM2.5</span><b>' + p.pm25 + ' <small>µg/m³</small></b></div>';
            if (!rows) rows = '<div class="aqp-note">Indeks ogólny stacji</div>';
            var hd = p.kolor || '#9aa7b0';
            var html =
              '<div class="aqp">' +
                '<div class="aqp-hd" style="background:' + hd + ';color:' + kontrast(hd) + '">' +
                  '<div class="aqp-src">' + p.zrodlo + '</div>' +
                  '<div class="aqp-name">' + p.nazwa + '</div>' +
                  (p.indeks ? '<div class="aqp-idx">' + p.indeks + '</div>' : '') +
                '</div>' +
                '<div class="aqp-bd">' + rows +
                  (p.url ? '<a class="aqp-more" href="' + p.url + '" target="_blank" rel="noopener">Więcej →</a>' : '') +
                '</div>' +
              '</div>';
            m.bindPopup(html, { className: 'aq-popup', maxWidth: 260, minWidth: 220 });
            grupa.push(m);
          });
          if (grupa.length) {
            var g = L.featureGroup(grupa);
            map.fitBounds(g.getBounds().pad(0.25));
          }
          if (info) {
            var parts = [];
            if (liczba['GIOŚ']) parts.push(liczba['GIOŚ'] + ' GIOŚ');
            if (liczba['Airly']) parts.push(liczba['Airly'] + ' Airly');
            if (liczba['LookO2']) parts.push(liczba['LookO2'] + ' LookO2');
            if (liczba['Syngeos']) parts.push(liczba['Syngeos'] + ' Syngeos');
            var txt = parts.length ? 'Punkty pomiarowe: ' + parts.join(' · ') + '.' : 'Brak danych do wyświetlenia.';
            if (!liczba['Airly'] && !liczba['Syngeos'] && !liczba['LookO2']) {
              txt += ' Lokalne pyłomierze (Airly, LookO2, Syngeos) pojawią się po skonfigurowaniu kluczy API.';
            }
            info.textContent = txt;
          }
        })
        .catch(function () {
          var info = document.getElementById('mapa-info');
          if (info) info.textContent = 'Nie udało się pobrać danych o jakości powietrza. Sprawdź na powietrze.gios.gov.pl';
        });
    }

    var s = document.createElement('script');
    s.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
    s.crossOrigin = '';
    s.onload = init;
    document.head.appendChild(s);
  })();
</script>
