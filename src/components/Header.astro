---
const links = [
  { href: '/', label: 'Start' },
  { href: '/o-nas/', label: 'O nas' },
  { href: '/historia/', label: 'Historia' },
  { href: '/dla-mieszkanca/', label: 'Dla mieszkańca' },
  { href: '/aktualnosci/', label: 'Aktualności' },
  { href: '/kontakt/', label: 'Kontakt' },
];
const path = Astro.url.pathname;
---
<header class="site-header">
  <div class="container hd">
    <a href="/" class="brand" aria-label="Strona główna — Mysłowicki Alarm Smogowy">
      <img src="/logo-poziomy.svg" alt="Mysłowicki Alarm Smogowy" width="240" height="62" />
    </a>
    <button class="nav-toggle" aria-label="Menu" aria-expanded="false" aria-controls="nav">
      <span></span><span></span><span></span>
    </button>
    <nav id="nav" class="nav">
      {links.map((l) => (
        <a href={l.href} class={path === l.href ? 'active' : ''} aria-current={path === l.href ? 'page' : undefined}>{l.label}</a>
      ))}
    </nav>
  </div>
</header>

<style>
  .site-header { position: sticky; top: 0; z-index: 50; background: rgba(255,255,255,0.92); backdrop-filter: blur(8px); border-bottom: 1px solid var(--border); }
  .hd { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding-top: 0.6rem; padding-bottom: 0.6rem; }
  .brand img { height: 60px; width: auto; display: block; }
  @media (max-width: 480px) { .brand img { height: 46px; } }
  .nav { display: flex; gap: 0.3rem; flex-wrap: wrap; }
  .nav a { padding: 0.5rem 0.8rem; border-radius: 999px; font-weight: 500; font-size: 0.95rem; color: var(--navy); }
  .nav a:hover { background: var(--bg-blue-soft); text-decoration: none; }
  .nav a.active { background: var(--blue); color: #fff; }
  .nav-toggle { display: none; flex-direction: column; gap: 5px; background: none; border: 0; cursor: pointer; padding: 8px; }
  .nav-toggle span { width: 26px; height: 2px; background: var(--navy); border-radius: 2px; transition: 0.2s; }
  @media (max-width: 860px) {
    .nav-toggle { display: flex; }
    .nav { position: absolute; top: 100%; left: 0; right: 0; flex-direction: column; background: #fff; border-bottom: 1px solid var(--border); padding: 0.5rem 1.25rem 1rem; gap: 0.2rem; display: none; }
    .nav.open { display: flex; }
    .nav a { padding: 0.7rem 0.8rem; }
  }
</style>

<script>
  const btn = document.querySelector('.nav-toggle');
  const nav = document.getElementById('nav');
  btn?.addEventListener('click', () => {
    const open = nav?.classList.toggle('open');
    btn.setAttribute('aria-expanded', String(!!open));
  });
</script>
