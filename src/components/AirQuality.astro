---
// Najbliższe oficjalne stacje GIOŚ (w Mysłowicach nie ma własnej stacji).
const stacje = [
  { id: 17318, nazwa: 'Katowice, ul. Dudy-Gracza', odl: '9 km' },
  { id: 837, nazwa: 'Sosnowiec, ul. Lubelska', odl: '9 km' },
];
---
<section class="aq" aria-label="Jakość powietrza">
  <div class="aq-head">
    <div>
      <span class="eyebrow">Jakość powietrza teraz</span>
      <p class="aq-sub">Mysłowice nie mają własnej stacji GIOŚ — pokazujemy najbliższe oficjalne pomiary. Dane lokalne (pyłomierze): <a href="https://airly.org/map/pl/" target="_blank" rel="noopener">mapa Airly</a>.</p>
    </div>
  </div>
  <div class="aq-grid">
    {stacje.map((s) => (
      <article class="aq-card" data-station={s.id}>
        <header>
          <h3>{s.nazwa}</h3>
          <span class="aq-dist">~{s.odl} od Mysłowic</span>
        </header>
        <div class="aq-index" data-index>
          <span class="aq-dot" aria-hidden="true"></span>
          <span class="aq-label">Ładowanie…</span>
        </div>
        <dl class="aq-vals">
          <div><dt>PM10</dt><dd data-pm10>—</dd></div>
          <div><dt>PM2.5</dt><dd data-pm25>—</dd></div>
        </dl>
      </article>
    ))}
  </div>
  <p class="aq-src">Źródło: <a href="https://powietrze.gios.gov.pl/pjp/current" target="_blank" rel="noopener">GIOŚ — Państwowy Monitoring Środowiska</a>. Pomiar orientacyjny, aktualizowany co godzinę.</p>
</section>

<style>
  .aq { background: var(--bg-blue-soft); border: 1px solid var(--border); border-radius: var(--radius); padding: 1.6rem; }
  .aq-sub { color: var(--text-muted); font-size: 0.95rem; margin: 0.2rem 0 1.2rem; max-width: 64ch; }
  .aq-grid { display: grid; gap: 1rem; }
  @media (min-width: 640px) { .aq-grid { grid-template-columns: 1fr 1fr; } }
  .aq-card { background: #fff; border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 1.1rem 1.2rem; }
  .aq-card header { display: flex; justify-content: space-between; align-items: baseline; gap: 0.6rem; }
  .aq-card h3 { font-size: 1.02rem; margin: 0; }
  .aq-dist { color: var(--text-muted); font-size: 0.8rem; white-space: nowrap; }
  .aq-index { display: flex; align-items: center; gap: 0.55rem; margin: 0.7rem 0; }
  .aq-dot { width: 14px; height: 14px; border-radius: 50%; background: #c7d2db; flex: none; }
  .aq-label { font-weight: 600; color: var(--navy); }
  .aq-vals { display: flex; gap: 1.5rem; margin: 0; }
  .aq-vals dt { font-size: 0.78rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; }
  .aq-vals dd { margin: 0; font-size: 1.15rem; font-weight: 700; color: var(--navy); }
  .aq-src { font-size: 0.82rem; color: var(--text-muted); margin: 1rem 0 0; }
</style>

<script>
  const API = 'https://api.gios.gov.pl/pjp-api/v1/rest';
  const skala = [
    { max: 0, kolor: '#c7d2db', txt: 'brak danych' },
    { lvl: 0, kolor: '#57b108', txt: 'bardzo dobry' },
    { lvl: 1, kolor: '#b0dd10', txt: 'dobry' },
    { lvl: 2, kolor: '#ffd911', txt: 'umiarkowany' },
    { lvl: 3, kolor: '#e58100', txt: 'dostateczny' },
    { lvl: 4, kolor: '#e50000', txt: 'zły' },
    { lvl: 5, kolor: '#990000', txt: 'bardzo zły' },
  ];

  function pick(obj: any, ...keys: string[]) {
    for (const k of keys) {
      for (const realKey of Object.keys(obj || {})) {
        if (realKey.toLowerCase().includes(k.toLowerCase())) return obj[realKey];
      }
    }
    return undefined;
  }

  async function fillStation(card: Element) {
    const id = card.getAttribute('data-station');
    try {
      const r = await fetch(`${API}/aqindex/getIndex/${id}`);
      if (!r.ok) throw new Error('http');
      const data = await r.json();
      const idxName = pick(data, 'nazwa kategorii indeksu', 'indexlevelname', 'kategoria');
      const lvl = pick(data, 'wartość indeksu', 'indexlevel', 'id');
      let s = skala.find((x) => 'lvl' in x && x.lvl === Number(lvl)) || skala[0];
      const dot = card.querySelector('.aq-dot') as HTMLElement;
      const label = card.querySelector('.aq-label') as HTMLElement;
      dot.style.background = s.kolor;
      label.textContent = (idxName && String(idxName)) || s.txt;
    } catch {
      const label = card.querySelector('.aq-label') as HTMLElement;
      label.textContent = 'sprawdź w GIOŚ';
      (card.querySelector('.aq-label')?.parentElement as HTMLElement)?.style.setProperty('opacity', '0.7');
    }
  }

  document.querySelectorAll('.aq-card').forEach(fillStation);
</script>
